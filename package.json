{
  "name": "stride-zero",
  "version": "1.2.0",
  "description": "Adaptive Expo running app for beginner running plans with guided sessions, reminders, and local progress tracking.",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
