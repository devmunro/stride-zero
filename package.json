    "expo-keep-awake": "~15.0.8",
    "expo-navigation-bar": "~5.0.9",
    "expo-notifications": "~0.32.16",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-safe-area-context": "5.6.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0"
